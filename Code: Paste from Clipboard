"""
Code: Paste from Clipboard
Created April 9, 2026

The following code demonstrates the most direct way is to call root.clipboard_get() inside
the lambda. Because this method can raise a TclError if the clipboard is empty or contains 
non-text data, it works best when wrapped in a helper function.

This version simply displays text from the clipboard to the commandline.
"""

import tkinter as tk


def paste_clipboard():
    try:
        # Retrieves text content from the system clipboard
        text = root.clipboard_get()
        print(f"Clipboard contains: {text}")
    except tk.TclError:
        # Handles cases where the clipboard is empty or lacks text
        print("Clipboard is empty or does not contain text.")


root = tk.Tk()
root.title("Clipboard Grabber")
root.geometry("250x150")

# btn = tk.Button(root, text="Grab Clipboard", command=lambda: paste_clipboard())
# When you use command=lambda: paste_clipboard(), lambda creates a new, anonymous function
# that lives in memory just to call the first one.  It's cleaner to simply call paste_clipboard

btn = tk.Button(root, text="Grab Clipboard", command=paste_clipboard)  
# Do not use command=paste_clipboard().  It will paste clipboard to console on program launch
btn.pack(pady=25)

root.mainloop()

