"""
Code: Pop-up Window (One at a Time)
Created: April 27, 2026

Description: Demonstrates the Toplevel Tkinter widget, which spawns
new Tkinter windows or "pop-ups."  Toplevel is a better alternative to spawning 
extra tkinter windows by using tk().

This version only allows one Toplevel Window to open at a time.
"""

import tkinter as tk


# Track the window reference
settings_window = None

def on_popup_close():
    """
    Restores 'topmost' to the main window when the popup is closed.
    """
    global settings_window

    settings_window.destroy()
    # Put the main window back on top of everything
    root.attributes("-topmost", True)


def open_settings():
    """
    Initializes the settings window or refocuses it if already open.
    
    Toggles the main window's 'topmost' attribute to allow the popup 
    to take focus, ensuring a single-instance overlay.
    """
    global settings_window

    # Prevent duplicates
    if settings_window is not None and settings_window.winfo_exists():
        settings_window.lift()
        return

    # Turn OFF topmost for the main window so the popup can be seen
    root.attributes("-topmost", False)

    # This creates a new window on top of the root
    settings_window = tk.Toplevel(root)
    settings_window.title("Secondary Window")
    # Width 200, Height 100, positioned at X=150, Y=150 from screen corner
    settings_window.geometry("200x100+150+150")

    # Handle what happens when the user clicks the 'X' button
    settings_window.protocol("WM_DELETE_WINDOW", on_popup_close)

    tk.Label(settings_window, text="Only one of these can exist!\n
             It can go above the main window!").pack(pady=20)


# Create User Interface
root = tk.Tk()
root.title("Code: Pop-up Window (One at a Time)")
# Width 300, Height 200, positioned at X=100, Y=100 from screen corner
root.geometry("300x200+100+100")

# Set Main Window to stay on top initially
root.attributes("-topmost", True)

# Create a button to trigger the child window
tk.Button(root, text="Open Settings", command=open_settings).pack(pady=50)

root.mainloop()

