"""
Code: Toplevel Pop-Up Window
Created: April 26, 2026

Description: Demonstrates the Toplevel Tkinter widget, which spawns new Tkinter 
windows or "pop-ups."  Toplevel is a better alternative to spawning extra tkinter 
windows by using tk().
"""

import tkinter as tk


def open_popup():
    # This creates a new window on top of the root
    popup = tk.Toplevel(root)
    popup.title("Secondary Window")
    popup.geometry("200x100")


# Create User Interface
root = tk.Tk()
root.title("Demo: Toplevel Pop-Up Window")
# Width 300, Height 200, positioned at X=100, Y=100 from screen corner
root.geometry("300x200+100+100")


# Create a button to trigger the child window
tk.Button(root, text="Launch a Pop-up", command=open_popup).pack(pady=50)


root.mainloop()
 
