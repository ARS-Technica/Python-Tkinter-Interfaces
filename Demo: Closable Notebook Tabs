"""
Demo: Closable Notebook Tabs
Created: July 16, 2026

Description: Demonstrates a closable notebook tab behavior using a custom ttk 
style layout. The user can click the 'x' to close the tab, and the underlying 
frame is destroyed to free memory.
"""

import tkinter as tk
from tkinter import ttk


# Create Widgets --------------------------------------------------------------
def handle_tab_click(event: tk.Event) -> None:
    """
    Processes clicks to determine if the user clickedthe close icon.
    """
    notebook = event.widget
    clicked_element = notebook.identify(event.x, event.y)

    # Identify if the click landed on the tab structure
    if "tab" in clicked_element or "label" in clicked_element:
        # Determine which numerical tab index was clicked
        tab_index = notebook.index(f"@{event.x},{event.y}")

        # Get the pixel bounding box of the clicked tab: [X, Y, Width, Height]
        tab_rect = notebook.bbox(tab_index)
        
        if tab_rect:
            # If the click was in the last 20 pixels of the tab, they clicked the 'X'
            click_is_on_x = event.x > (tab_rect[0] + tab_rect[2] - 20)

    # If the click was in the last 20 pixels of the tab, they clicked the 'X'

    # Pull the underlying frame widget and cleanly destroy it

    return None


# Create User Interface -------------------------------------------------------
def create_application() -> None:
    """
    Sets up the Tkinter window and initialize the widget bindings.
    """
    root = tk.Tk()
    root.title("Demo: Closable Notebook Tabs")
    root.geometry("400x300")

    # 1. Establish modern theme base
    style_engine = ttk.Style()
    style_engine.theme_use("clam")

    # 2. Initialize a standard Notebook
    notebook = ttk.Notebook(root)
    notebook.pack(expand=True, fill="both", padx=10, pady=10)

    # 3. Bind the click release event directly to the global function handler
    notebook.bind("<ButtonRelease-1>", handle_tab_click)

    # 4. Add open tabs iteratively for demonstration
    for i in range(1, 4):
        frame = ttk.Frame(notebook)
        label = ttk.Label(frame, text=f"This is the interior of Tab {i}")
        label.pack(padx=20, pady=20)
        
        # Append "  ✕" directly to the tab titles
        notebook.add(frame, text=f"Tab {i}   ✕") 

    root.mainloop()


# Main Application Entry ------------------------------------------------------
if __name__ == "__main__":
    create_application()

