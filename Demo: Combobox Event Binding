"""
Demo: Combobox Event Binding
Created: April 9, 2026

Description: Demonstrates triggering a function immediately upon the selection
of an option in a combobox (without the addition of using a button as a trigger).

The next version of this program, "Demo Combobox without Current Selection", will "shrink 
the list" of combobox options so that the (current) active option is not not an available choice.
"""

import tkinter as tk
from tkinter import ttk  # Required for Combobox


# Combobox Functions ---------------------------------------------------------
def on_selection(event):
    """
    Triggered by the <<ComboboxSelected>> event.
    The 'event' argument is automatically passed by Tkinter.
    Updates the display_label with the chosen value.
    """
    # Get the current value from the widget
    selected_item = combobox_menu.get()
    # print(f"User selected: {selected_item}")  # Print to console

    # Clear the text widget to update it
    display_info.config(state="normal") # Enable editing
    display_info.delete("1.0", tk.END)  # Clear current text
    
    # Insert the normal text
    display_info.insert(tk.END, "You've selected: ")
    
    # Insert the bold text using the 'bold_font' tag
    display_info.insert(tk.END, selected_item, "bold_font")
    
    # Center the text and disable editing
    display_info.tag_add("center", "1.0", "end")
    display_info.config(state="disabled") # Make it read-only


# Create User Interface Functions ---------------------------------------------------------
def create_combobox(parent):    
    """
    Defines inventory data, calculates dimensions, and initializes the combobox.
    Returns the combobox, the initial list of items, and the title string.
    """
    global combobox_menu, directions, OPTIONS # Shared with reset function

    # Define the options for the dropdown
    OPTIONS = ["C++", "C#", "Java", "JavaScript", "Python", "R", "Ruby", "Rust"]
    directions = "Pick your favorite programming language"

    # Calculate the Dynamic Width for the Combobox
    # Calculate the length of the longest string in the list or directions
    longest_option = max(OPTIONS + [directions], key=len)
    # Set a variable for the longest Combobox option
    dynamic_width = len(longest_option) + 2 # Add a little padding for the arrow button
    # UI will automatically adjust itself without having to manually count pixels.

    # Create the Combobox Menu
    combobox_menu = ttk.Combobox(root, values=OPTIONS, width=dynamic_width, state="readonly")
    combobox_menu.set(directions)  # Set default directions text
    combobox_menu.pack(pady=20, padx=20)

    # Bind the selection event to our function
    combobox_menu.bind("<<ComboboxSelected>>", on_selection)
    # The first argument is the event pattern, the second is the function name 

    return combobox_menu


def create_user_interface():
    """
    Initializes and packs all UI components for the application.
    """
    global combobox_menu, display_info, reset_button, root 

    # Main Application Window ---------------------------------------------------------
    root = tk.Tk()
    root.title("Demo: Combobox Event Binding")
    root.geometry("300x150")

    # Create the Combobox Menu
    combobox_menu = create_combobox(root)

    # Create the Text Widget
    # We use tk.Text because it supports multiple styles (tags) in one line
    display_info = tk.Text(root, height=1, font=("Arial", 10), 
                        bg=root.cget("bg"), bd=0, highlightthickness=0)

    # Configure Text Tags
    # Create the Bold Style Tag
    display_info.tag_configure("bold_font", font=("Arial", 10, "bold"))
    # Create a Centering Tag
    display_info.tag_configure("center", justify='center')

    # Initial Text
    display_info.insert(tk.END, "What is your favorite language?")
    display_info.tag_add("center", "1.0", "end")
    display_info.config(state="disabled")
    display_info.pack(fill="x", pady=10)


# Main Application Window ---------------------------------------------------------
if __name__ == "__main__":
    create_user_interface() # Initialize UI
    root.mainloop()

