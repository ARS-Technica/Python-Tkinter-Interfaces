"""
Demo: Combobox Event Binding
Created: April 10, 2026

Description: Demonstrates triggering a function immediately upon the selection
of an option in a combobox (without the addition of using a button as a trigger).
"""

import tkinter as tk
from tkinter import ttk

def on_selection(event):
    selected_item = combo.get()
    
    # 1. Clear the text widget to update it
    display_info.config(state="normal") # Enable editing
    display_info.delete("1.0", tk.END)  # Clear current text
    
    # 2. Insert the normal text
    display_info.insert(tk.END, "You've selected: ")
    
    # 3. Insert the bold text using the 'bold_font' tag
    display_info.insert(tk.END, selected_item, "bold_font")
    
    # 4. Center the text and disable editing
    display_info.tag_add("center", "1.0", "end")
    display_info.config(state="disabled") # Make it read-only

root = tk.Tk()
root.title("Feature: Styled Output")
root.geometry("400x200")

options = ["C++", "Java", "Python", "Rust"]
placeholder = "Pick a language"
dynamic_width = len(max(options + [placeholder], key=len)) + 2

combo = ttk.Combobox(root, values=options, width=dynamic_width, state="readonly")
combo.set(placeholder)
combo.pack(pady=20)
combo.bind("<<ComboboxSelected>>", on_selection)

# --- The Advanced Display Widget ---
# We use tk.Text because it supports multiple styles (tags) in one line
display_info = tk.Text(root, height=1, font=("Arial", 10), 
                       bg=root.cget("bg"), bd=0, highlightthickness=0)

# Create the Bold Style Tag
display_info.tag_configure("bold_font", font=("Arial", 10, "bold"))
# Create a Centering Tag
display_info.tag_configure("center", justify='center')

# Initial Text
display_info.insert(tk.END, "What is your favorite language?")
display_info.tag_add("center", "1.0", "end")
display_info.config(state="disabled")
display_info.pack(fill="x", pady=10)

root.mainloop()

