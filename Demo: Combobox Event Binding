"""
Demo: Combobox Event Binding
Created: April 10, 2026

Description: Demonstrates triggering a function immediately upon the selection
of an option in a combobox (without the addition of using a button as a trigger).
"""

import tkinter as tk
from tkinter import ttk  # Required for Combobox

def on_selection(event): 
    """
    Triggered by the <<ComboboxSelected>> event.
    The 'event' argument is automatically passed by Tkinter.
    """
    # Get the current value from the widget
    selected_item = combo.get()
    print(f"User selected: {selected_item}")   


root = tk.Tk()
root.title("Demo: Combobox Event Binding")
root.geometry("300x150")

# 1. Define the options for the dropdown 
options = ["C++", "JavaScript", "Python", "Rust"]

# 2. Create the Combobox 
combo = ttk.Combobox(root, values=options, state="readonly")
combo.set("Pick a programming language")  # Set default placeholder text
combo.pack(pady=40)

# 3. Bind the selection event to our function
# The first argument is the event pattern, the second is the function name 
combo.bind("<<ComboboxSelected>>", on_selection)

root.mainloop()

