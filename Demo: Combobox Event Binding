"""
Demo: Combobox Event Binding
Created: April 10, 2026

Description: Demonstrates triggering a function immediately upon the selection
of an option in a combobox (without the addition of using a button as a trigger).
"""

import tkinter as tk
from tkinter import ttk

def on_selection(event):
    selected_item = combo.get()
    
    # 1. Change the first label to the prefix
    prefix_label.config(text="You've selected: ", font=("Arial", 10, "normal"), slant="roman")
    
    # 2. Change the second label to the bold result
    result_label.config(text=selected_item, font=("Arial", 10, "bold"))

root = tk.Tk()
root.title("Combobox Feature")
root.geometry("400x200")

# --- Combobox Logic ---
options = ["C++", "Java", "Python", "Rust"]
placeholder = "Pick a language"
dynamic_width = len(max(options + [placeholder], key=len)) + 2

combo = ttk.Combobox(root, values=options, width=dynamic_width, state="readonly")
combo.set(placeholder)
combo.pack(pady=20)
combo.bind("<<ComboboxSelected>>", on_selection)

# --- The "Single Line" Label Trick ---
# We use a Frame to hold two labels so they appear as one line
label_container = tk.Frame(root)
label_container.pack(pady=10)

# This label starts as the question, then turns into "You've selected: "
prefix_label = tk.Label(label_container, text="What is your favorite language?", font=("Arial", 10, "italic"))
prefix_label.pack(side="left")

# This label is empty until you select something, then it shows the BOLD item
result_label = tk.Label(label_container, text="", font=("Arial", 10, "bold"))
result_label.pack(side="left")

root.mainloop()

