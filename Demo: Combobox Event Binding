"""
Demo: Combobox Event Binding
Created: April 10, 2026

Description: Demonstrates triggering a function immediately upon the selection
of an option in a combobox (without the addition of using a button as a trigger).
"""

import tkinter as tk
from tkinter import ttk  # Required for Combobox

def on_selection(event): 
    """
    Updates the UI state from 'Question' to 'Selection'
    while bolding only the result.
    """
    selected_item = combo.get()
    
    # Update the static label text and remove italics
    static_label.config(text="You've selected: ", font=("Arial", 10, "normal"))
    
    # Update the dynamic label with the bolded result
    dynamic_bold_label.config(text=selected_item)

root = tk.Tk()
root.title("Demo: Combobox Event Binding")
root.geometry("350x200")

options = ["C++", "C#", "Java", "JavaScript", "Python", "R", "Ruby", "Rust"]
placeholder = "Pick a programming language"

# Pythonic Dynamic Width
dynamic_width = len(max(options + [placeholder], key=len)) + 2

# Combobox Setup 
combo = ttk.Combobox(root, values=options, width=dynamic_width, state="readonly")
combo.set(placeholder)
combo.pack(pady=20)
combo.bind("<<ComboboxSelected>>", on_selection)

# Label Setup 
# A Frame container allows us to switch from one full-width sentence 
# to two labels side-by-side seamlessly.
label_frame = tk.Frame(root)
label_frame.pack(pady=10)

# Part 1: Starts as the full question
static_label = tk.Label(label_frame, text="What is your favorite programming language?", font=("Arial", 10, "italic"))
static_label.pack(side="left")

# Part 2: Hidden/Empty until selection
dynamic_bold_label = tk.Label(label_frame, text="", font=("Arial", 10, "bold"))
dynamic_bold_label.pack(side="left")

root.mainloop()


