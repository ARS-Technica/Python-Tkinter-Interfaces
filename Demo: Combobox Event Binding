"""
Demo: Combobox Event Binding
Created: April 10, 2026

Description: Demonstrates triggering a function immediately upon the selection
of an option in a combobox (without the addition of using a button as a trigger).
"""

import tkinter as tk
from tkinter import ttk  # Required for Combobox

def on_selection(event): 
    """
    Triggered by the <<ComboboxSelected>> event.
    The 'event' argument is automatically passed by Tkinter.
    Updates the display_label with the chosen value.
    """
    # Get the current value from the widget
    selected_item = combo.get()
    # print(f"User selected: {selected_item}")  # Print to console   
    display_label.config(text=f"You've selected: ", fg="black")
    
    # Configure the bold portion of the text label
    display_text = tk.Text(root, height=1, width=30, bd=0, bg=root.cget("bg"))
    display_text.tag_configure("bold_tag", font=("Arial", 10, "bold"))

    # Insert the variable with the 'bold' tag
    display_text.insert("end", selected_item, "bold_tag")
    # Make it read-only again
    display_text.config(state="disabled") 


root = tk.Tk()
root.title("Demo: Combobox Event Binding")
root.geometry("300x150")

# Define the options for the dropdown 
options = ["C++", "C#", "Java", "JavaScript", "Python", "R", "Ruby", "Rust"]
placeholder = "Pick a programming language"

# Select a Dynamic Width for the Combobox
# Calculate the length of the longest string in the list
longest_option = max(options + [placeholder], key=len)
# Set a variable for the longest Combobox option
dynamic_width = len(longest_option) + 2 # Add a little padding for the arrow button

# Create the Combobox 
combo = ttk.Combobox(root, values=options, width=dynamic_width, state="readonly")
combo.set(placeholder)  # Set default placeholder text
combo.pack(pady=20, padx=20)

# Bind the selection event to our function
combo.bind("<<ComboboxSelected>>", on_selection)
# The first argument is the event pattern, the second is the function name 

# Label Setup
display_label = tk.Label(root, text="What is your favorite programming language?", font=("Arial", 10, "italic"))
display_label.pack(pady=10)

root.mainloop()

