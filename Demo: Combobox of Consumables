"""
Demo: Combobox of Consumables
Created: April 19, 2026

Description: Demonstrates triggering a function immediately upon the selection
of an option in a combobox (without the addition of using a button as a trigger).

This version also emonstrates Dynamic Attribute Modification, the ability to change a widget's data while the program is still running.  Specifically, this version removes
each option from the combobox once its been chosen until no further options are available.

I thought that this would work well in a PyGame platformer in which you could only
use each collected player buff once.  Otherwise, not terribly useful.
"""

import tkinter as tk
from tkinter import ttk  # Required for Combobox


# Global Values ---- ---------------------------------------------------------
"""
This entire section of code would normally be a CLASS, but my intent is to 
demonstrate Tkinter widgets, not building a fully functional program.
"""

# Global Game State (Stat Counters)
stats = {"Health": 5, "Magic": 0, "Strength": 0}

# Maximum Stat Values  # This is getting complex, but this stops stats from overpowering
MAX_STATS = {"Health": 10, "Magic": 10, "Strength": 50}
INVENTORY = ["Health", "Mana", "Resurrection", "Super Strength"]

directions = "Choose which potion to consume..."


# Combobox Functions ---------------------------------------------------------

# Breaking up the over-sized on_selection Function
def apply_combobox_selection(combobox_selection):
    """
    Updates the stats dictionary based on the combobox selection, 
    respecting the MAX_STATS caps.
    """
    # Get the current value from the widget
    selected_item = combobox_menu.get()
    # print(f"User selected: {selected_item}")  # Print to console

    if combobox_selection == "Health":
        stats["Health"] = min(stats["Health"] + 1, MAX_STATS["Health"])
    elif combobox_selection == "Mana":
        stats["Magic"] = min(stats["Magic"] + 1, MAX_STATS["Magic"])
    elif combobox_selection == "Resurrection":
        stats["Health"] = MAX_STATS["Health"]
    elif combobox_selection == "Super Strength":
        stats["Strength"] = min(stats["Strength"] + 10, MAX_STATS["Strength"])


def on_selection(event):
    """
    Core logic of the program.  Handles interaction between combobox and stat 
    counters.

    Determines which option was selected and updates the stats dictionary using 
    the min() function to respect the MAX_STATS caps.

    ! This functions has been divided into a series of smaller functions
    """    

    # Get the current value from the widget
    selected_item = combobox_menu.get()
    # print(f"User selected: {selected_item}")  # Print to console

    # Update the stats dictionary based on the combobox selection 
    apply_combobox_selection(selected_item)

    # Update the Stat Counters (labels)
    update_stats_display()

    # Update the Combobox List
    remove_used_item(selected_item)


def remove_used_item(item_to_remove):
    """
    Removes the selected option from possible combobox values.
    If empty, disables the menu and reveals the Reset button.
    """
    # Moved code from on_selection

    # Update the Combobox List
    # Get the current tuple of options
    current_options = list(combobox_menu['values'])

    if item_to_remove in current_options:
        current_options.remove(item_to_remove)
        combobox_menu['values'] = current_options

    if not current_options:
        combobox_menu.config(state="disabled")

        # Clear the text widget to update it
        display_info.config(state="normal") # Enable editing
        display_info.delete("1.0", tk.END)  # Clear current text

        # Insert the text into a label
        display_info.insert(tk.END, "DANGER!\n", "alert")            
        display_info.insert(tk.END, "You have consumed all of your potions!", "bold_font") 

        # Center the text and disable editing
        display_info.tag_add("center", "1.0", "end")
        display_info.config(state="disabled") # Make it read-only

        # Empty State Text
        reset_button.pack(pady=5)
    else:
        combobox_menu.set(directions)


def reset_combobox_selections():
    """
    Restores the application to its initial state.

    - Repopulates combobox values from the INVENTORY constant.
    - Sets combobox state back to readonly.
    - Clears and updates 'display_info' with the starting prompt.
    - Removes the 'reset_button' from the layout using pack_forget.
    """
    # Establish default values to restore
    global stats 
    stats = {"Health": 5, "Magic": 0, "Strength": 0} 

    # Restore the original list of options
    combobox_menu['values'] = INVENTORY

    # Re-enable the combobox and reset the title
    combobox_menu.config(state="readonly")
    combobox_menu.set(directions)

    update_stats_display()    

    # Reset the Text Widget to its initial message
    display_info.config(state="normal")
    display_info.delete("1.0", tk.END)
    display_info.insert(tk.END, "Which potion you want to consume?")
    display_info.tag_add("center", "1.0", "end")
    display_info.config(state="disabled")

    # Hide the reset button again
    reset_button.pack_forget() # Creates "Ghost button"


# Stat Counter Functions ----------------------------------------------------------------
def update_stats_display(selected_item=None):
    """
    Synchronizes the text on the UI labels with the current values in the stats dictionary.
    """
    # Update the Stat Labels
    h_curr, h_max = stats['Health'], MAX_STATS['Health']
    m_curr, m_max = stats['Magic'], MAX_STATS['Magic']
    s_curr, s_max = stats['Strength'], MAX_STATS['Strength']

    # Using :02 for 2-digit padding and :02 for the max values as well
    # Format: 05/10, 00/10, 00/50
    health_label.config(text=f"Health:\n{h_curr:02}/{h_max:02}")
    magic_label.config(text=f"Magic:\n{m_curr:02}/{m_max:02}")
    strength_label.config(text=f"Strength:\n{s_curr:02}/{s_max:02}")

    # Redistributed into on_selection Function:

    # Update the Text Widget Feedback
    if selected_item:
        # Clear the text widget to update it
        display_info.config(state="normal") # Enable editing
        display_info.delete("1.0", tk.END)  # Clear current text

        # Insert the normal text
        display_info.insert(tk.END, "You've selected: ")

        # Insert the bold text using the 'bold_font' tag
        display_info.insert(tk.END, selected_item, "bold_font")

        # Center the text and disable editing
        display_info.tag_add("center", "1.0", "end")

        display_info.config(state="disabled") # Make it read-only


# Create User Interface Functions --------------------------------------------------------
def create_combobox(parent):    
    """
    Defines inventory data, calculates dimensions, and initializes the combobox.
    Returns the combobox, the initial list of items, and the title string.
    """
    global combobox_menu, directions, INVENTORY # Shared with reset function

    # Define the options for the dropdown 
    INVENTORY = ["Health", "Mana", "Resurrection", "Super Strength"]
    directions = "Choose which potion to consume..."

    # Calculate the Dynamic Width for the Combobox
    # Calculate the length of the longest string in the list or title
    longest_option = max(INVENTORY + [directions], key=len)
    # Set a variable for the longest Combobox option
    dynamic_width = len(longest_option) + 2 # Add a little padding for the arrow button
    # UI will automatically adjust itself without having to manually count pixels.

    # Create and configure the Combobox Widget
    combobox_menu = ttk.Combobox(parent, values=INVENTORY, width=dynamic_width, state="readonly")
    combobox_menu.set(directions)  # Set default title text
    combobox_menu.pack(pady=20, padx=20)

    # Bind the selection event to our function
    combobox_menu.bind("<<ComboboxSelected>>", on_selection)
    # The first argument is the event pattern, the second is the function name

    return combobox_menu #, directions, INVENTORY


def create_stat_frame(parent):
    """
    Creates a frame and the labels for Health, Magic, and Strength.
    Returns the frame, the initial stats, and a title label
    """
    global health_label, magic_label, strength_label

    # Create a container frame to hold the labels side-by-side
    stat_frame = tk.Frame(parent)
    stat_frame.pack(pady=10)

    # Health Label
    health_label = tk.Label(stat_frame, text="", fg="red", font=("Arial", 10, "bold"), justify="center")
    health_label.grid(row=0, column=0, padx=15)

    # Magic Label
    magic_label = tk.Label(stat_frame, text="", fg="blue", font=("Arial", 10, "bold"), justify="center")
    magic_label.grid(row=0, column=1, padx=15)

    # Strength Label
    strength_label = tk.Label(stat_frame, text="", fg="green", font=("Arial", 10, "bold"), justify="center")
    strength_label.grid(row=0, column=2, padx=15)

    return stat_frame


def create_user_interface():
    """
    Initializes and packs all UI components for the application.
    """
    global combobox_menu, directions, display_info, INVENTORY, reset_button, root # Allows functions to access these

    # Main Application Window ---------------------------------------------------------
    root = tk.Tk()
    root.title("Demo: Combobox of Consumables")
    root.geometry("350x250") # Made taller for Stats (stat_frame)

    # Create the Stat Frame
    stat_frame = create_stat_frame(root)

    # Create the Combobox 
    combobox_menu = create_combobox(root)

    # Create the Text Widget
    # We use tk.Text because it supports multiple styles (tags) in one line
    display_info = tk.Text(root, height=2, font=("Arial", 10), 
                        bg=root.cget("bg"), bd=0, highlightthickness=0)
    # Note: height must equal 2 in order for "DANGER!\n" ... "You have consumed all of your potions!" to appear without truncating second line.


    # Configure Text Tags
	# Create a red color tag near your other tag_configure lines
    display_info.tag_configure("alert", foreground="red", font=("Arial", 10, "bold"))
    # Create the Bold Style Tag
    display_info.tag_configure("bold_font", font=("Arial", 10, "bold"))
    # Create a Centering Tag
    display_info.tag_configure("center", justify='center')

    # Set Initial Text
    display_info.insert(tk.END, "Which potion do you want to consume?")
    display_info.tag_add("center", "1.0", "end")
    display_info.config(state="disabled")
    display_info.pack(fill="x", pady=10)

    # Pre-create Reset Button.  Don't .pack() it yet.
    reset_button = tk.Button(root, text="Restock Inventory", command=reset_combobox_selections)

    # Initialize labels
    update_stats_display()


# Main Application Window ---------------------------------------------------------
if __name__ == "__main__":
    create_user_interface() # Initialize UI
    root.mainloop()

