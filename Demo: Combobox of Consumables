# Create User Interface Functions --------------------------------------------------------
def create_combobox(parent):    
    """
    Defines inventory data, calculates dimensions, and initializes the combobox.
    Returns the combobox, the initial list of items, and the title string.
    """
    global combobox_menu, directions, INVENTORY # Shared with reset function

    # Define the options for the dropdown 
    INVENTORY = ["Health", "Mana", "Resurrection", "Super Strength"]
    directions = "Choose which potion to consume..."

    # Calculate the Dynamic Width for the Combobox
    # Calculate the length of the longest string in the list or title
    longest_option = max(INVENTORY + [directions], key=len)
    # Set a variable for the longest Combobox option
    dynamic_width = len(longest_option) + 2 # Add a little padding for the arrow button
    # UI will automatically adjust itself without having to manually count pixels.

    # Create and configure the Combobox Widget
    combobox_menu = ttk.Combobox(parent, values=INVENTORY, width=dynamic_width, state="readonly")
    combobox_menu.set(directions)  # Set default title text
    combobox_menu.pack(pady=20, padx=20)

    # Bind the selection event to our function
    combobox_menu.bind("<<ComboboxSelected>>", on_selection)
    # The first argument is the event pattern, the second is the function name

    return combobox_menu #, directions, INVENTORY


def create_stat_frame(parent):
    """
    Creates a frame and the labels for Health, Magic, and Strength.
    Returns the frame, the initial stats, and a title label
    """
    global health_label, magic_label, strength_label

    # Create a container frame to hold the labels side-by-side
    stat_frame = tk.Frame(parent)
    stat_frame.pack(pady=10)

    # Health Label
    health_label = tk.Label(stat_frame, text="", fg="red", font=("Arial", 10, "bold"))
    health_label.grid(row=0, column=0, padx=15)

    # Magic Label
    magic_label = tk.Label(stat_frame, text="", fg="blue", font=("Arial", 10, "bold"))
    magic_label.grid(row=0, column=1, padx=15)

