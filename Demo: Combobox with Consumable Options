"""
Demo: Combobox with Consumable Options
Created: April 14, 2026

Description: Demonstrates triggering a function immediately upon the selection
of an option in a combobox (without the addition of using a button as a trigger).

This version also emonstrates Dynamic Attribute Modification, the ability to change a widget's data while the program is still running.  Specifically, this version removes
each option from the combobox once its been chosen until no further options are available.

I thought that this would work well in a PyGame platformer in which you could only
use each collected player buff once.  Otherwise, not terribly useful.
"""

import tkinter as tk
from tkinter import ttk  # Required for Combobox


# Combobox Functions ---------------------------------------------------------
def on_selection(event):
    """
    Triggered by the <<ComboboxSelected>> event.
    The 'event' argument is automatically passed by Tkinter.
    Updates the display_label with the chosen value.

    Each time an option is selected, it is removed from the 
    combobox until there are no options remaining.

    Added "Reset" button mostly for debugging purposes.
    """    

    # Get the current value from the widget
    selected_item = combo.get()
    # print(f"User selected: {selected_item}")  # Print to console

    # Clear the text widget to update it
    display_info.config(state="normal") # Enable editing
    display_info.delete("1.0", tk.END)  # Clear current text

    # Insert the normal text
    display_info.insert(tk.END, "You've selected: ")

    # Insert the bold text using the 'bold_font' tag
    display_info.insert(tk.END, selected_item, "bold_font")

    # Center the text and disable editing
    display_info.tag_add("center", "1.0", "end")

    display_info.config(state="disabled") # Make it read-only


    # Update the Combobox List
    # Get the current tuple of options
    current_options = list(combo['values'])
    
    # Remove the selected item if it exists in the list
    if selected_item in current_options:
        current_options.remove(selected_item)
        
        # Apply the filtered list back to the combobox
        combo['values'] = current_options
        
        # Reset the combobox to the placeholder if no options are left
        if not current_options:
            combo.set("No options remaining")
            # combo.event_generate('<Escape>') 
            # No. '<Escape>' this only simulates a keypress to close the list if it's already open.
            
            combo.config(state="disabled") # Disable the widget entirely

            # Clear the text widget to update it
            display_info.config(state="normal") # Enable editing
            display_info.delete("1.0", tk.END)  # Clear current text

            # Insert the normal text
            display_info.insert(tk.END, "DANGER!\n", "bold_font")            
            display_info.insert(tk.END, "You have consumed all of your potions!\n")

            # Center the text and disable editing
            display_info.tag_add("center", "1.0", "end")
            display_info.config(state="disabled") # Make it read-only

            # Reset combo box options
            # reset_button = tk.Button(root, text="Reset List", command=reset_demo)
            # reset_button.pack(pady=5)

            # Reveal the reset button rather than creating a new button
            reset_button.pack(pady=5)
        else:
            combo.set(title)


def reset_demo():
    # Restore the original list of options
    combo['values'] = INVENTORY 
    
    # Re-enable the combobox and reset the title
    combo.config(state="readonly")
    combo.set(title)
    
    # Reset the Text Widget to its initial message
    display_info.config(state="normal")
    display_info.delete("1.0", tk.END)
    display_info.insert(tk.END, "Choose which potion do you want to consume.")
    display_info.tag_add("center", "1.0", "end")
    display_info.config(state="disabled")

    # Hide the reset button again
    reset_button.pack_forget()


# Main Application Window ---------------------------------------------------------
root = tk.Tk()
root.title("Demo: Combobox with Consumable Options")
root.geometry("300x200") # Made slightly taller for the button


# Create the Combobox -------------------------------------------------------------
# Define the options for the dropdown 
INVENTORY = ["Health", "Mana", "Resurrection", "Super Strength"]
title = "Choose which potion to consume..."

# Select a Dynamic Width for the Combobox
# Calculate the length of the longest string in the list or title
longest_option = max(INVENTORY + [title], key=len)
# Set a variable for the longest Combobox option
dynamic_width = len(longest_option) + 2 # Add a little padding for the arrow button
# UI will automatically adjust itself without having to manually count pixels.

# Create the Combobox 
combo = ttk.Combobox(root, values=INVENTORY, width=dynamic_width, state="readonly")
combo.set(title)  # Set default title text
combo.pack(pady=20, padx=20)

# Bind the selection event to our function
combo.bind("<<ComboboxSelected>>", on_selection)
# The first argument is the event pattern, the second is the function name 


# The Advanced Text Widget -----------------------------------------------------------
# We use tk.Text because it supports multiple styles (tags) in one line
display_info = tk.Text(root, height=2, font=("Arial", 10), 
                       bg=root.cget("bg"), bd=0, highlightthickness=0)
# Note: height must equal 2 in order for "DANGER!\n" ... "You have consumed all of your potions!" to appear without truncating second line.

# Create the Bold Style Tag
display_info.tag_configure("bold_font", font=("Arial", 10, "bold"))
# Create a Centering Tag
display_info.tag_configure("center", justify='center')

# Initial Text
display_info.insert(tk.END, "Which potion do you want to consume?")
display_info.tag_add("center", "1.0", "end")
display_info.config(state="disabled")
display_info.pack(fill="x", pady=10)


# PRE-CREATE THE RESET BUTTON.  Don't .pack() it yet.
reset_button = tk.Button(root, text="Restock Inventory", command=reset_demo)

root.mainloop()

