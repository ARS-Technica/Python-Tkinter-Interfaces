"""
Demo: Combobox without Current Selection
Created: April 11, 2026

Description: Demonstrates triggering a function immediately upon the selection
of an option in a combobox (without the addition of using a button as a trigger).

This version also emonstrates Dynamic Attribute Modification, the ability to change a widget's data while the program is still running.  Specifically, this version "shrinks 
the list" of combobox options so that the (current) active option is not not an available choice.
"""

import tkinter as tk
from tkinter import ttk  # Required for Combobox


# Combobox Functions ---------------------------------------------------------
def on_selection(event):
    """
    Triggered by the <<ComboboxSelected>> event.
    The 'event' argument is automatically passed by Tkinter.
    Updates the display_label with the chosen value.

    DOES NOT DISPLAY CURRENTLY SELECTED COMBOBOX OPTION
    """
    # Get the current value from the widget
    selected_item = combo.get()
    # print(f"User selected: {selected_item}")  # Print to console

    # Clear the text widget to update it
    display_info.config(state="normal") # Enable editing
    display_info.delete("1.0", tk.END)  # Clear current text
    
    # Insert the normal text
    display_info.insert(tk.END, "You've selected: ")
    
    # Insert the bold text using the 'bold_font' tag
    display_info.insert(tk.END, selected_item, "bold_font")

    # Center the text and disable editing
    display_info.tag_add("center", "1.0", "end")
    display_info.config(state="disabled") # Make it read-only

    # Update the Combobox List
    # Create a new list containing everything EXCEPT the one currently selected
    # This uses a list comprehension: a Pythonic way to filter lists
    updated_options = [opt for opt in options if opt != selected_item]
    
    # Apply the filtered list back to the combobox
    combo['values'] = updated_options



