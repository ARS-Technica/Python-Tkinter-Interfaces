"""
Demo: Dependent Dropdown Boxes
Created: April 25, 2026

Description: Demonstrates how to make a second combobox dependent on a first combobox.

The trick is to use the <<ComboboxSelected>> event of the first box to trigger a function that reconfigures the values of the second box.
"""

import random
import tkinter as tk
from tkinter import ttk  # Required for Combobox


# Data Structure --------------------------------------------------------------
"""
This entire section of code would normally be a CLASS, but my intent is to 
demonstrate Tkinter widgets, not building a fully functional program.
"""

# This acts as a simple database substitute for our dropdown options.  The keys 
# are the options for the first box, and the values are the lists of options for 
# the second box.
PROVISIONING_DATA = {
    "Arts & Design": ["Adobe Creative Cloud", "Maya 3D", "Ableton Live"],
    "Business": ["Microsoft Office Pro", "Tableau", "QuickBooks", "SAP Client"],
    "Engineering": ["AutoCAD", "MATLAB", "SolidWorks", "Python Data Stack"],
    "General Staff": ["Standard Office Suite", "Zoom", "Slack"]
    # Add other departments here
}


# Combobox Functions ----------------------------------------------------------
def log_output(tag, message):
    """
    Helper to update the Text widget with formatted logs.
    """
    output_log.config(state="normal")
    output_log.delete("1.0", tk.END)

    # Insert message with associated tag (success, error, or normal)
    output_log.insert(tk.END, message, tag)
    output_log.tag_add("center", "1.0", "end")
    output_log.config(state="disabled")


def provision_workstation():
    '''
    The final button should collect the data from both boxes and a generate 
    an "Asset Tag" for a mock system record.
    '''
    global department_cb, output_log, root, software_cb

    department = department_cb.get()
    software = software_cb.get()

    # Validation: Ensure selections aren't placeholders
    valid_departments = PROVISIONING_DATA.keys()
    invalid_software = ["Select Software...", "Waiting for Department...", "N/A"]    
    
    # Validation: Ensure selections were actually made
    if department in valid_departments and software not in invalid_software:
        asset_tag = f"ASSET-{random.randint(1000, 9999)}"
        # Ideally, this number would be saved to a JSON, which would be check
        # to prevent duplicates, but this is a demonstation of the widget, not
        # a full-fledged program.

        # Creating a detailed multi-line record for the log
        record = (f"PROVISIONING SUCCESSFUL\n\n"
                  f"Asset Tag: {asset_tag}\n"
                  f"Department: {department}\n"
                  f"Software: {software}")
        log_output("success", record)
    else:
        log_output("error", "ERROR: Please select both a Department and a Software Bundle.")


def update_software_list(event):
    """
    Refreshes the Software box based on the Department selection.

    Triggered when the Category Combobox changes.
    Updates the Model Combobox with relevant items.
    """
    global department_cb, selected_category

    selected_department = department_cb.get()
    
    # Lookup the matching list from our dictionary
    new_software_list = PROVISIONING_DATA.get(selected_department, [])

    # Update the second combobox's values
    software_cb['values'] = new_software_list
    
    # Reset the second box so it doesn't show old info
    if new_software_list:
        software_cb.config(state="readonly")        
        software_cb.set("Select Software...")
    else:
        software_cb.config(state="disabled")
        software_cb.set("N/A")

    # Clear output log for a fresh start
    log_output("normal", f"Department '{selected_department}' selected.\nSoftware list updated.")


# Create User Interface Functions ---------------------------------------------
def create_user_interface():
    """
    Initializes and packs all UI components for the application.
    """
    global root, department_cb, software_cb, output_log # Allows functions to access these

    # Main Application Window -------------------------------------------------
    # Setup standard Tkinter window
    root = tk.Tk()
    root.title("Demo: Dependent Dropdown Comboboxes")
    root.geometry("450x400")

    # Title Header
    tk.Label(root, text="System Provisioning Portal", font=("Arial", 12, "bold")).pack(pady=15)

    # Department Selection
    department_combobox_directions = tk.Label(root, text="Step 1: Select Department", font=("Arial", 10, "bold"))
    department_combobox_directions.pack()
    department_cb = ttk.Combobox(root, values=list(PROVISIONING_DATA.keys()), state="readonly", width=35)
    department_cb.set("Select Department...")
    department_cb.pack(pady=5)
    department_cb.bind("<<ComboboxSelected>>", update_software_list)

    # Software Selection
    software_combobox_directions = tk.Label(root, text="Step 2: Available Software Bundles", font=("Arial", 10, "bold"))
    software_combobox_directions.pack()
    software_cb = ttk.Combobox(root, values=[], state="disabled", width=35)
    software_cb.set("Waiting for Department...")
    software_cb.pack(pady=5)

    # Action Button
    provision_btn = tk.Button(root, text="Provision Workstation",               command=provision_workstation, bg="#2ecc71", fg="white", 
                              font=("Arial", 10, "bold"), cursor="hand2")
    provision_btn.pack(pady=20)

    # Output Log (Using a Text Label)
    output_log = tk.Text(root, height=4, width=50, bg=root.cget("bg"), bd=0, font=("Arial", 10))

    # Text formatting tags for updates
    output_log.tag_configure("success", foreground="green", font=("Arial", 10, "bold"))
    output_log.tag_configure("error", foreground="red")
    output_log.tag_configure("center", justify='center')
    output_log.tag_configure("bold", justify='center', foreground="black", font=("Arial", 10, "bold"))    
    output_log.pack(pady=10)

    # Set initial text message
    log_output("normal", "System Ready. Please select a department to begin.")


# Main Application Window ---------------------------------------------------------
if __name__ == "__main__":
    create_user_interface() # Initialize UI
    root.mainloop()

