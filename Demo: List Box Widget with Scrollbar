"""
Demo: List Box Widget with Scrollbar
Created: May 18, 2026

Description: Demonstrates the Tkinter List Box widget used to manage 
collections of text data such as playlists, file explorers, or task managers.
This iteration includes a Scrollbar widget that is linked to the Listbox for 
better navigation when the list exceeds the length of the Listbox.

Future List Box demonstrations will expand this code to include multiple 
Listboxes that interact with each other, but this project focuses on a single 
Listbox and its basic functionality.
"""

import tkinter as tk


# Widget Functions ------------------------------------------------------------
def auto_scroll(scrollbar: tk.Scrollbar, first: str | float, last: str | float) -> None:
    """
    Dynamically shows or hides the scrollbar depending on content size.
    'first' and 'last' are string percentages (0.0 to 1.0) sent by the listbox.
    Accepts str or float to satisfy modern strict IDE type engines.
    """
    if float(first) <= 0.0 and float(last) >= 1.0:
        # The entire list is visible; remove the scrollbar from view
        scrollbar.pack_forget()
    else:
        # Content overflows; show the scrollbar snapped to the right edge
        scrollbar.pack(side="right", fill="y")

    # Update the scrollbar handle position and size based on the listbox's view        
    scrollbar.set(first, last)


def add_custom_item(entry_widget, label_bottom, label_top, listbox_widget):
    '''
    Retrieves text from the entry widget, validates it, and appends it to the listbox.
    All dependent widgets are passed in directly, eliminating global requirements.
    '''
    # 1. Grab the text from the input entry box and strip whitespace
    user_text = entry_widget.get().strip()

															
    if user_text != "":
        listbox_widget.insert(tk.END, user_text)  # Append to bottom of list
        entry_widget.delete(0, tk.END)            # Clear out the input box automatically
        
        # Give feedback to the user
        label_top.config(text="Added to list:")
        label_bottom.config(text=f"{user_text}")
    else:
        label_top.config(text="Cannot add an empty item!")
        label_bottom.config(text="")


def clear_selection(label_bottom, label_top, listbox_widget):
    '''
    Clears the currently highlighted item from display label
    '''
	# 1. Clear the visual highlight from index 0 all the way to the END
    listbox_widget.selection_clear(0, tk.END)

    # 2. Reset the display text labels to their default state
    label_top.config(text="Select an Item!")
    label_bottom.config(text="")


def display_selection(label_bottom, label_top, listbox_widget):
    '''
    Retrieves the currently highlighted item in the Listbox and displays it.
    '''
	# Return a tuple of selected index numbers										  
    selected_indices = listbox_widget.curselection()

	# Check that the user made a selection before displaying the result																   
    if selected_indices:
        index = selected_indices[0]  # Grab the first index from the tuple
        chosen_item = listbox_widget.get(index)  # Convert index to the text string
        
        # Update the Label for feedback
        label_top.config(text="Selected Item:")
        label_bottom.config(text=f"{chosen_item}")
    else:
        label_top.config(text="Please select an item first!")


# Widget Creation -------------------------------------------------------------
def build_listbox(parent):
    '''
    Creates a Listbox widget, populates it with selections, and returns it.
    '''
    # 1. Create the Listbox widget
    # "width" represents characters, 'height' represents rows visible at once																 
    listbox_widget = tk.Listbox(parent, width=25, height=10, activestyle="none")

    # 2. Populate the Listbox using .insert(), a clean array list using a loop
    # Syntax: widget.insert(tk.END, string)
    starting_colors = ["Red", "Orange", "Yellow", "Green", "Blue"]

    for color in starting_colors:
        # "tk.END" is a shortcut for "add to the bottom"														
        listbox_widget.insert(tk.END, color)

    # Bind the Listbox selection event to the display_selection function																		
    return listbox_widget


# User Interface --------------------------------------------------------------
def create_user_interface():
    '''
    Creates the main application window and calls the function to build widgets.
    '''
    root = tk.Tk()
    root.title("Demo: List Box Widget")
    root.geometry("300x350")

    # Build the Listbox and pack it into the main window
    listbox_widget = build_listbox(root)
    listbox_widget.pack(pady=15)

    # Create Status Labels to Display Text
    status_display_top = tk.Label(root, text="Select an Item!", font=("Consolas", 11, "bold"))
    status_display_top.pack(pady=(5, 0))

    status_display_bottom = tk.Label(root, text="", font=("Consolas", 11, "bold"))
    status_display_bottom.pack(pady=(0, 5))

    # Create an Entry widget for adding new items to the Listbox
    new_item_entry = tk.Entry(root, width=25, font=("Arial", 10))
    new_item_entry.pack(pady=5)

    # Bind the Listbox selection event using a Lambda shortcut
    # Arguments passed match parameters alphabetically: label_bottom, label_top, listbox_widget
    listbox_widget.bind(
        "<<ListboxSelect>>", 
        lambda event: display_selection(status_display_bottom, status_display_top, listbox_widget)
    )

    # Container Frame for Buttons ---------------------------------------------
    button_frame = tk.Frame(root)
    button_frame.pack(pady=10)    

    # Build and place the Add Selection Button
    # Arguments passed match parameters alphabetically: new_item_entry, status_display_bottom, status_display_top, listbox_widget
    add_button = tk.Button(
        button_frame, 
        text="Add Selection", 
        command=lambda: add_custom_item(new_item_entry, status_display_bottom, status_display_top, listbox_widget)
    )
    add_button.pack(side="left", padx=5)

    # Build and place the Clear Selection Button
    # Arguments passed match parameters alphabetically: status_display_bottom, status_display_top, listbox_widget
    clear_button = tk.Button(
        button_frame, 
        text="Clear Selection", 
        command=lambda: clear_selection(status_display_bottom, status_display_top, listbox_widget)
    )
    clear_button.pack(side="left", padx=5)

    root.mainloop()


# Main Application Window -----------------------------------------------------
if __name__ == "__main__":
    create_user_interface()

