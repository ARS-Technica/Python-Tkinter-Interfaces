"""
Demo: Listbox Shuttle Widget
Created: May 23, 2026

Description: Demonstrates the use of multiple Tkinter Listbox widgets coordinated
to manage a collection of text data in what is sometimes referred to as a 
"shuttle" interface.  In a full application, these widgets could be used for 
playlists, file explorers, or task managers.  

This iteration includes a Scrollbar widget that is linked to the Listbox for 
better navigation when the list exceeds the length of the Listbox.

This project is an expansion on my earlier "Demo: Listbox Widget with Scrollbar"
project, which used a single Listbox in order to demonstrate its basic 
functionality.
"""

import tkinter as tk


# Widget Functions ------------------------------------------------------------
def auto_scroll(scrollbar: tk.Scrollbar, first: str | float, last: str | float) -> None:
    """Dynamically shows or hides a specific scrollbar depending on content size."""
    if float(first) <= 0.0 and float(last) >= 1.0:
        scrollbar.pack_forget()
    else:
        scrollbar.pack(side="right", fill="y")
        
    scrollbar.set(first, last)


def shuttle_item(status_display_bottom: tk.Label, status_display_top: tk.Label, source_listbox: tk.Listbox, target_listbox: tk.Listbox) -> None:
    """
    Transfers the selected item from a source listbox to a target listbox.
    Parameters and arguments are organized in strict alphabetical order.
    """
    selected_indices = source_listbox.curselection()

    if selected_indices:
        index = selected_indices[0]
        item_text = source_listbox.get(index)

        # 1. Clear target's current focus highlights first
        target_listbox.selection_clear(0, tk.END)

        # 2. Add the item string to the target list and remove it from the source list
        target_listbox.insert(tk.END, item_text)
        source_listbox.delete(index)

        # 3. Highlight the newly transferred item and scroll it into view
        new_index = target_listbox.size() - 1
        target_listbox.selection_set(new_index)
        target_listbox.see(new_index)

        # 4. Clear selections remaining on the source listbox
        source_listbox.selection_clear(0, tk.END)

        # 5. Shift focus automatically to the top remaining item after a transfer 
        if source_listbox.size() > 0: # if any items remain
            source_listbox.selection_set(0)
            source_listbox.see(0)

        # 6. Provide real-time UI feedback
        status_display_top.config(text=f"Moved:")
        status_display_bottom.config(text=f"{item_text:^20}")
    else:
        status_display_top.config(text="Please highlight an item to move first!")
        status_display_bottom.config(text=" ")


# Widget Creation -------------------------------------------------------------
def build_shuttle_list(parent: tk.Misc) -> tuple[tk.Frame, tk.Listbox]:
    """
    Constructs an isolated frame containing a single Listbox and an 
    independent auto-hiding scrollbar tracking engine.
    """
    list_container = tk.Frame(parent)
    scrollbar = tk.Scrollbar(list_container, orient="vertical")

    listbox_widget = tk.Listbox(
        list_container, 
        width=22, 
        height=10, 
        activestyle="none"
    )
    listbox_widget.pack(side="left", fill="both", expand=True)

    # Attach this scrollbar securely to this listbox wrapper context
    listbox_widget.config(
        yscrollcommand=lambda first, last: auto_scroll(scrollbar, first, last)
    )
    scrollbar.config(command=listbox_widget.yview)

    return list_container, listbox_widget


# User Interface --------------------------------------------------------------
def create_user_interface() -> None:
    """Assembles and manages the side-by-side interactive application lifecycle."""
    root = tk.Tk()
    root.title("Demo: Listbox Widget")
    root.geometry("500x375")
    root.resizable(False, False)


    # Container Frame for UI Layout -------------------------------------------
    main_layout_frame = tk.Frame(root)
    main_layout_frame.pack(pady=15)




    # Container for Left Listbox ---------------------------------------------- 
    left_frame = tk.Frame(main_layout_frame)
    left_frame.pack(side="left", padx=10)
    
    tk.Label(left_frame, text="Available Pool", font=("Arial", 10, "bold")).pack(pady=(0, 5))
    list_container_left, listbox_left = build_shuttle_list(left_frame)
    list_container_left.pack()




    # Container for Center Buttons --------------------------------------------
    center_button_frame = tk.Frame(main_layout_frame)
    center_button_frame.pack(side="left", padx=10, pady=(20, 0))


    # Button: Shuttle Right (Move Available -> Selected)
    # Alphabetical Arguments: status_display_bottom, status_display_top, listbox_left (source), listbox_right (target)
    move_right_button = tk.Button(
        center_button_frame, 
        text="Add >", 
        font=("Arial", 10, "bold"),
        width=10,
        command=lambda: shuttle_item(status_display_bottom, status_display_top, listbox_left, listbox_right)
    )
    move_right_button.pack(pady=5)

    # Button: Shuttle Left (Move Selected -> Available)
    # Alphabetical Arguments: status_display_bottom, status_display_top, listbox_right (source), listbox_left (target)
    move_left_button = tk.Button(
        center_button_frame, 
        text="< Remove", 
        font=("Arial", 10, "bold"),
        width=10,
        command=lambda: shuttle_item(status_display_bottom, status_display_top, listbox_right, listbox_left)
    )
    move_left_button.pack(pady=5)




    # Container for Right Listbox ---------------------------------------------    
    right_frame = tk.Frame(main_layout_frame)
    right_frame.pack(side="left", padx=10)

    tk.Label(right_frame, text="Selected Items", font=("Arial", 10, "bold")).pack(pady=(0, 5))
    list_container_right, listbox_right = build_shuttle_list(right_frame)
    list_container_right.pack()




    # Text Display Beneath Listboxes ------------------------------------------    
    # Feedback Text Label
    status_display_top = tk.Label(root, text="Select an item to transfer", font=("Consolas", 11, "bold"))
    status_display_top.pack(side="top", pady=(20, 0)) # Pack top line first

    status_display_bottom = tk.Label(root, text="", font=("Consolas", 11, "bold"))
    status_display_bottom.pack(side="top", pady=(0, 20)) # Stack next line directly below it




    # Test Data for Listboxes -------------------------------------------------
    starting_features = [
        "White", "Red", "Orange", "Yellow", "Green", "Blue", "Indigo", "Violet", "Black"
    ]
    for feature in starting_features:
        listbox_left.insert(tk.END, feature)


    root.mainloop()


# Main Application Window -----------------------------------------------------
if __name__ == "__main__":
    create_user_interface()

