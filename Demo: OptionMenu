"""
Demo: OptionMenu
Create: April 29, 2026

Description: Demonstrates how to make a OptionMenu, a simple alternative to the
classic drop-down comboboxes.  In Tkinter, this is a more basic dropdown than 
the Combobox, but it can be useful for simple selections.
"""

import tkinter as tk




# Create User Interface Functions ---------------------------------------------
def create_user_interface():
    """
    Initializes and packs all UI components for the application.
    """
    global root, department_cb, software_cb, output_log # Allows functions to access these

    # Main Application Window -------------------------------------------------
    # Setup standard Tkinter window

    root = tk.Tk()
    root.title("OptionMenu Demo")
    root.geometry("300x250")

    # Define the Variable (The "Source of Truth")
    # This variable will always hold the current selection of the menu 
    selected_value = tk.StringVar(root)
    selected_value.set("Choose a Priority") # Set the initial placeholder

    # Define the Options 
    options = ["High Priority", "Medium Priority", "Low Priority", "Informational"]

    # Create the OptionMenu
    # Syntax: OptionMenu(parent, variable, *options_list)
    menu = tk.OptionMenu(root, selected_value, *options)
    # The '*' unpacks the list into individual arguments for the widget

    menu.config(width=20)
    menu.pack(pady=30)

    # Link a callback to the variable
    selected_value.trace_add("write", display_choice) # listens for 'write' events 
    
    # Display Label
    output_label = tk.Label(root, text="Waiting for selection...", font=("Arial", 10))
    output_label.pack(pady=10)


# Main Application Window ---------------------------------------------------------
if __name__ == "__main__":
    create_user_interface() # Initialize UI
    root.mainloop()

