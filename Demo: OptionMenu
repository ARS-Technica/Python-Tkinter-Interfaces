"""
Demo: OptionMenu
Create: April 29, 2026

Description: Demonstrates how to make a OptionMenu, a simple alternative to the
classic drop-down comboboxes.  In Tkinter, this is a more basic dropdown than 
the Combobox, but it can be useful for simple selections.
"""

from random import choice
import tkinter as tk


# Data Mapping ----------------------------------------------------------------
# A dictionary to separate data (colors) from logic (the display function)

COLOR_MAP = {
    "High Priority": "#e74c3c",      # Red
    "Medium Priority": "#f39c12",    # Orange
    "Low Priority": "#27ae60",       # Green
    "Deferred": "#3498db",           # Blue
    "Choose a Priority": "black",      # Default Black
    "Cancelled": "black"               # Default Black
}


# Logic Functions -------------------------------------------------------------
def display_choice(*args):
    """
    Triggered whenever the StringVar changes.
    Updates the UI based on the variable's current state.
    The *args is used because trace_add passes internal details we don't need.
    """
    # Define the variable by GETTING it from the StringVar
    current_selection = selected_value.get()

    # Call the get_priority_style function to get widget text color and text
    text_to_display, color_to_use = get_priority_style(current_selection)

    # If priority is canelled, return the font weight to normal.
    if current_selection in ["Choose a Priority", "Cancelled"]:
        weight = "normal"
    else:
        weight = "bold" # All other priorities should be bold for emphasis

    # Update the widget text formatting with the color and text returned above
    output_label.config(
        text=text_to_display, 
        fg=color_to_use, 
        font=("Arial", 10, weight)
    )


def get_priority_style(choice):
    """
    Returns the color and text for a given choice.
    This function doesn't know 'output_label' exists.
    """
    color = COLOR_MAP.get(choice, "black")
 
    if choice == "Choose a Priority":
        return "Please select a priority...", color, "normal"
    
    if choice == "Cancelled":
        # Return the immediate message; the 'delay' happens in the UI function
        return "Selection Cancelled.", color, "normal"
        # Change the else statement to a different message in 3 seconds.

    return f"Selected: {choice}", color, "bold"


def reset_display(text):
    """
    Callback for root.after.
    Returns the label to its original state after a delay.
    """

    output_label.config(
        text="Please select a priority...", 
        fg="black", 
        font=("Arial", 10, "normal")
    )


# Create User Interface Functions ---------------------------------------------
def create_user_interface():
    """
    Initializes and packs all UI components for the application.
    """
    global root, selected_value, output_label # Allows functions to access these

    # Main Application Window -------------------------------------------------
    # Setup standard Tkinter window

    root = tk.Tk()
    root.title("Demo: OptionMenu Demo")
    root.geometry("300x200")


    # Text Label Setup --------------------------------------------------------

    # Text Label to show the current selection and change color based on choice
    output_label = tk.Label(root, text="Waiting for selection...", font=("Arial", 10))
    output_label.pack(pady=(30, 10))


    # Option Menu Setup -------------------------------------------------------

    # Define the Variable (The "Source of Truth")
    # This variable will always hold the current selection of the menu 
    selected_value = tk.StringVar(root)
    selected_value.set("Choose a Priority") # Set the initial placeholder

    # Define the Options 
    options = ["High Priority", "Medium Priority", "Low Priority", "Deferred", "Cancelled"]

    # Create the OptionMenu
    # Syntax: OptionMenu(parent, variable, *options_list)
    menu = tk.OptionMenu(root, selected_value, *options)
    # The '*options' unpacks the list into individual arguments for the widget

    menu.config(width=20, cursor="hand2")
    menu.pack(pady=20)

    # Link a callback to the variable
    selected_value.trace_add("write", display_choice) # listens for 'write' events 


# Main Application Window ---------------------------------------------------------
if __name__ == "__main__":
    create_user_interface() # Initialize UI
    root.mainloop()

