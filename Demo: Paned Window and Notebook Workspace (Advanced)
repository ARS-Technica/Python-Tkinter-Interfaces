# Sidebar Navigation Logic ----------------------------------------------------
def _on_notebook_tab_change(event: tk.Event, treeview_widget: ttk.Treeview, notebook_key: str) -> None:
    """
    Listens to active tab shifts and expands/highlights the correct sidebar leaf.
    """
    notebook = event.widget

    # Safety Check: Only process updates if this notebook is currently the visible layer
    # Check if this notebook is sitting at the very top of the stacking order
    if notebook.winfo_parent() != "":
        # Find out what the top-most widget in the grid stack is right now
        # If this notebook isn't active, don't run this synchronization
        pass

    try:
        current_tab_index = notebook.index(notebook.select())
    except tk.TclError:
        return

    # Loop through the treeview rows to locate the matching key and index values
    for parent_id in treeview_widget.get_children():
        for child_id in treeview_widget.get_children(parent_id):
            vals = treeview_widget.item(child_id, "values")
            if vals and vals[0] == notebook_key and int(vals[1]) == current_tab_index:
                if treeview_widget.focus() != child_id:
                    # Automatically expand the parent node folder group
                    treeview_widget.item(parent_id, open=True)
                    # Highlight and focus the matching child node leaf
                    treeview_widget.selection_set(child_id)
                    treeview_widget.focus(child_id)
                return


def _on_sidebar_select(event: tk.Event, notebook_map: dict, container_frame: tk.Frame) -> None:
    """
    Catches sidebar row clicks and changes focus to new active notebook tab.

    Args:
        event (tk.Event): The event object triggered by the sidebar selection.
        notebook (ttk.Notebook): The notebook instance to switch tabs on.
    """
    treeview_widget = event.widget
    selected_item = treeview_widget.focus()
    
    if not selected_item:
        return
        
    item_values = treeview_widget.item(selected_item, "values")
    if not item_values:
        return  # Clicked a generic non-mapped header node
        
    notebook_key = item_values[0]
    tab_index = int(item_values[1])

    # 1. Fetch the targeted notebook component
    target_notebook = notebook_map.get(notebook_key)
    if not target_notebook:
        return

    # 2. Layer Switching Engine: Lift the chosen notebook to the top of the stack
    target_notebook.lift()

    # 3. Focus Toggle: Flip to the matching inner tab index channel
    if target_notebook.index(target_notebook.select()) != tab_index:
        target_notebook.select(tab_index)


