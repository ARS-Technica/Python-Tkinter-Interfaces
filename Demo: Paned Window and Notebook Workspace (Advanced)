# Widget Creation -------------------------------------------------------------
def build_dashboard_layers(paned_window: ttk.PanedWindow) -> tuple[tk.Frame, dict]:
    """
    Generates an overlay frame layout stacking independent notebook workspace layers.

    Args:
        paned_window (ttk.PanedWindow): The parent PanedWindow to attach the dashboard to.
    Returns:    
        tuple: A tuple containing the dashboard container frame and a mapping of notebook keys to notebook instances.
    """
    # This core wrapper frame will anchor all notebooks inside the same pixel boundaries
    dashboard_container = tk.Frame(paned_window)
    notebook_map = {}

    # Workspace Notebook 1
    dev_notebook = ttk.Notebook(dashboard_container)
    dev_notebook.grid(row=0, column=0, sticky="nsew")

    tab_dash = ttk.Frame(dev_notebook)
    dev_notebook.add(tab_dash, text="📊 Analytics Dashboard")
    ttk.Label(tab_dash, text="Development Cluster Metrics", font=CONFIG["FONT_HEADER"]).pack(anchor="w", padx=20, pady=20)

    tab_shell = ttk.Frame(dev_notebook)
    dev_notebook.add(tab_shell, text="💻 Shell Terminal Console")
    ttk.Label(tab_shell, text="Developer Sandbox Local Shell Environment", font=CONFIG["FONT_HEADER"]).pack(anchor="w", padx=20, pady=20)

    # Workspace Notebook 2 
    admin_notebook = ttk.Notebook(dashboard_container)
    admin_notebook.grid(row=0, column=0, sticky="nsew")
    
    tab_rules = ttk.Frame(admin_notebook)
    admin_notebook.add(tab_rules, text="⚙️ Global System Rules")
    ttk.Label(tab_rules, text="Cluster Operations & Security Configurations", font=CONFIG["FONT_HEADER"]).pack(anchor="w", padx=20, pady=20)
    
    tab_vault = ttk.Frame(admin_notebook)
    admin_notebook.add(tab_vault, text="🔒 Database Key Vault")
    ttk.Label(tab_vault, text="Encrypted Asset Storage Credentials Access", font=CONFIG["FONT_HEADER"]).pack(anchor="w", padx=20, pady=20)

    # Lock sizing scale calculations to standard stretch ratios
    dashboard_container.rowconfigure(0, weight=1)
    dashboard_container.columnconfigure(0, weight=1)
    
    notebook_map["dev_notebook"] = dev_notebook
    notebook_map["admin_notebook"] = admin_notebook

    return dashboard_container, notebook_map


def build_sidebar_panel(paned_window: ttk.PanedWindow) -> tuple[ttk.Frame, ttk.Treeview]:
    """
    Constructs the expanding and collapsing multi-tier hierarchical sidebar navigation.

    Args:
        paned_window (ttk.PanedWindow): The parent PanedWindow to attach the sidebar to.
    Returns:
        ttk.Frame: The constructed sidebar frame.
    """
    # Create a simple frame and add it to the left side of the Paned Window 
    sidebar_frame = ttk.Frame(paned_window, width=240, relief="flat")
    sidebar_frame.pack_propagate(False) 
    
    # Generate internal sidebar layout elements
    sidebar_header = ttk.Label(sidebar_frame, text="Navigation Sidebar", font=CONFIG["FONT_HEADER"])
    sidebar_header.pack(anchor="w", padx=10, pady=(10, 5))  # Pack content inside the sidebar
    
    # Initialize the Sidebar Treeview (Enable folder-arrow behaviors)
    nav_tree = ttk.Treeview(sidebar_frame, show="tree", selectmode="browse")
    nav_tree.pack(fill="both", expand=True, padx=5, pady=5)
    
    # Level 1: Build Expanding Node Folders
    cluster_dev = nav_tree.insert("", tk.END, text="📁 Core Development Stack")
    cluster_adm = nav_tree.insert("", tk.END, text="📁 Server Administration Space")
    
    # Level 2: Build Child Leaves
    nav_tree.insert(cluster_dev, tk.END, text="📊 Analytics Dashboard", values=("dev_dash",))
    nav_tree.insert(cluster_dev, tk.END, text="💻 Shell Terminal Console", values=("dev_shell",))
    nav_tree.insert(cluster_adm, tk.END, text="⚙️ Global System Rules", values=("adm_rules",))
    nav_tree.insert(cluster_adm, tk.END, text="🔒 Database Key Vault", values=("adm_vault",))
    
    # Auto-expand development node by default on boot
    nav_tree.item(cluster_dev, open=True)
    
    return sidebar_frame, nav_tree


# User Interface Coordinator --------------------------------------------------
def create_user_interface() -> None:
    """
    Acts as the master coordinator for the multi-notebook cluster system.
    This function initializes the main Tkinter window, sets up the paned window layout,
    and constructs the sidebar and notebook layers.
    
    Returns:
        None
    """
    root = tk.Tk()
    root.title("Demo: Paned Window and Notebook Workspace (Advanced)")
    root.geometry("900x520")

    # Establish modern theme base
    style_engine = ttk.Style()
    style_engine.theme_use("clam")
    style_engine.configure("Treeview", rowheight=CONFIG["ROW_HEIGHT"], font=CONFIG["FONT_BODY"])

    # Paned Window Widget -----------------------------------------------
    # This acts as the master structural wrapper splitting the window horizontally
    master_paned_window = ttk.PanedWindow(root, orient=tk.HORIZONTAL)
    master_paned_window.pack(fill="both", expand=True, padx=10, pady=10)

    # 1. Build the widget layout frames cleanly into memory
    sidebar_frame, nav_tree = build_sidebar_panel(master_paned_window)
    dashboard_container, notebook_map = build_dashboard_layers(master_paned_window)

    # 2. Build the sidebar controller on the left edge wall
    # Explicitly add components to PanedWindow in precise LEFT-to-RIGHT sequence
    master_paned_window.add(sidebar_frame, weight=0)         # Added 1st -> Locks LEFT
    master_paned_window.add(dashboard_container, weight=1)   # Added 2nd -> Fills RIGHT

    # 3. Setup forward/backward binding synchronization controllers
    nav_tree.bind("<ButtonRelease-1>", lambda event: _on_sidebar_select(event, notebook_map))

    notebook_map["dev_notebook"].bind(
        "<<NotebookTabChanged>>", 
        lambda event: _on_notebook_tab_change(event, nav_tree, "dev_notebook")
    )
    notebook_map["admin_notebook"].bind(
        "<<NotebookTabChanged>>", 
        lambda event: _on_notebook_tab_change(event, nav_tree, "admin_notebook")
    )

    # Select the first element by default on boot (raise first workspace to top)
    first_leaf = nav_tree.get_children(nav_tree.get_children()[0])[0]
    nav_tree.selection_set(first_leaf)
    nav_tree.focus(first_leaf)
    # Boot initialization pass: raise first workspace to top
    notebook_map["dev_notebook"].lift()

    # Launch Application ---------------------------------------------------
    root.mainloop()

    return None


# Main Application Entry ------------------------------------------------------
if __name__ == "__main__":
    create_user_interface()

