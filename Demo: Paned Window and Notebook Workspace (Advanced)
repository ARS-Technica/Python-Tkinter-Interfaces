def _on_notebook_tab_change(event: tk.Event, treeview_widget: ttk.Treeview, notebook_key: str) -> None:
    """
    Listens to active tab shifts and expands/highlights the correct sidebar leaf.
    """
    notebook = event.widget

    # Safety Check: Only process updates if this notebook is currently the visible layer  
    try:
        # Check if this notebook is sitting at the very top of the stacking order  
        current_tab_index = notebook.index(notebook.select())
    except tk.TclError:
        # If this notebook isn't active, don't run this synchronization
        return

    # Loop through the treeview rows to locate the matching key and index values
    for parent_id in treeview_widget.get_children():
        for child_id in treeview_widget.get_children(parent_id):
            vals = treeview_widget.item(child_id, "values")
            if vals and vals[0] == notebook_key and int(vals[1]) == current_tab_index:
                if treeview_widget.focus() != child_id:
                    # Automatically expand the parent node folder group
                    treeview_widget.item(parent_id, open=True)
                    # Highlight and focus the matching child node leaf
                    treeview_widget.selection_set(child_id)
                    treeview_widget.focus(child_id)
                return


