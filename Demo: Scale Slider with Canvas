"""
Demo: Scale Widget with Canvas
Created: May 4, 2026

Description: Demonstrates using a Scale to manipulate geometric 
coordinates on a Canvas widget in real-time.

Scaling a shape on a Canvas is where you truly start to see the power of Tkinter
for graphics, data visualization, and interactive tools.

Tkinter's standard Canvas widget doesn't support anti-aliasing (the technique used to blur the pixels at the edge of a shape to make them look smooth). Because Tkinter is built on a library from the 90s, its circles can look a bit "pixelated" or "stair-stepped," especially as they get larger.  However, you can soften the look by:

    Setting the outline to the same color as the fill.

    Setting the width of the outline to 2 or 3 pixels.
"""

import tkinter as tk
# from turtle import fill
from PIL import Image, ImageDraw, ImageTk
# To get smoother, anti-aliased edges in Tkinter, we need to use Pillow (PIL).


# Global Variables ------------------------------------------------------------

# Styling color palette
BG_COLOR = (236, 240, 241)     # Light Gray (RGB)
BORDER_COLOR = (44, 62, 80)    # Dark Navy (RGB)
FILL_COLOR = (52, 152, 219)    # Blue (RGB)

#BORDER_COLOR = "#2c3e50"       # Dark Navy/Slate
#FILL_COLOR = "#3498db"         # Blue

BORDER_WIDTH = 6                # Thickness of the smoothed border


# Slider Functions ------------------------------------------------------------
def calculate_geometry(radius, canvas_size):
    """
    Calculates the bounding box coordinates based on the center of the canvas.  Handles only the math.
    """
    center = canvas_size // 2

    # Calculate bounding box
    x1, y1 = center - radius, center - radius
    x2, y2 = center + radius, center + radius

    return [x1, y1, x2, y2]


def render_circle_frame(coords, size, fill, border, border_width):
    """
    Creates the anti-aliased Image object using Pillow.
    Handles only the graphics.
    """
    # Create a base image with a solid background color
    img = Image.new("RGB", (size, size), BG_COLOR)
    # Use RGB to match the canvas background
    draw = ImageDraw.Draw(img)

    draw.ellipse(coords, fill=fill, outline=border, width=border_width)

    return ImageTk.PhotoImage(img)

