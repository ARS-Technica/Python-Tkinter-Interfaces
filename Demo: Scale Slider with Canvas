# User Interface Functions ---------------------------------------------
def create_user_interface():
    global root, drawing_area

    root = tk.Tk()
    root.title("Demo: Scale Slider with Canvas")
    root.geometry("350x450")


    # The canvas widget containing a shape to be altered
    drawing_area = tk.Canvas(
        root, 
        width=300, 
        height=300, 
        bg="#ecf0f1", 
        highlightthickness=0
    )
    drawing_area.pack(pady=20)

    # Initial shape creation



    # The label for the directions
    directions = tk.Label(root, text="Adjust Font Size")
    '''
    In Tkinter, the built-in label option for a horizontal Scale is hardcoded 
    to align to the top-left corner of the widget's area. So, there needs to be 
    a separate label or widget to center the directions.
    '''

    # Scale Widget Setup
    font_slider = tk.Scale(
        root, 
        from_=10,  # Starting value
        to=72,  # Ending value
        orient="horizontal",  # Either horizontal or vertical
        length=300,
        highlightthickness=0,  # Removes the focus border gap
        command=update_font_size  # Function to call on change
    )

    # Set a default starting value
    font_slider.set(12)

    # pack() will center these widgets relative to each other by default
    directions.pack(pady=(20,0))  # Space above the label, but 0 below
    font_slider.pack(pady=(0,20)) # 0 space above the slider, space below


    # Status display
    status_label = tk.Label(root, text="Current Font Size: 12px", fg="gray")
    status_label.pack(pady=10)


# Main Application Window -----------------------------------------------------
if __name__ == "__main__":
    create_user_interface()  # Initialize UI
