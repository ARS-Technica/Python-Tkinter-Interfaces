"""
Demo: Scale Widget with Rotation
Created: May 8, 2026

Description: Demonstrates the tk.Scale widget used to control 
numerical ranges. This demo maps slider values to the rotation
of a shape on a canvas widget using Pillow.
"""

import tkinter as tk
from PIL import Image, ImageDraw, ImageTk


# Global Variables ------------------------------------------------------------
# Global Styling Constants
BG_COLOR = (236, 240, 241)
FILL_COLOR = (52, 152, 219)
BORDER_COLOR = (44, 62, 80)
CANVAS_SIZE = 300


# Slider Functions ------------------------------------------------------------
def render_rotated_square(angle):
    """
    Creates the anti-aliased square in a transparent buffer 
    and rotates it using Pillow.
    """
    # Create a larger buffer to prevent corner clipping during rotation
    buffer_size = 250

    # Create an RGBA image for the shape itself
    shape_image = Image.new("RGBA", (buffer_size, buffer_size), (0, 0, 0, 0))
    draw = ImageDraw.Draw(shape_image)

    # Draw a static square in the center of the buffer
    draw.rectangle([75, 75, 175, 175], fill=FILL_COLOR, outline=BORDER_COLOR, width=5)  # [x1, y1, x2, y2]

    # Rotate the buffer
    rotated = shape_image.rotate(-angle, resample=Image.BICUBIC)
    # Pillow rotates counter-clockwise by default, so use -angle for clockwise rotation

    return ImageTk.PhotoImage(rotated)


def handle_rotation(value):
    """
    Orchestrates the calculation and rendering process:
    Updates coordinates and applies a contrasting border.
    Renders a smoothed square and border using Pillow's 
    anti-aliasing and rotates it using Pillow.
    
    Triggered by the slider to update the UI.
    """
    global tkinter_image

    angle = int(value)

    # Render the new frame
    tkinter_image = render_rotated_square(angle)

    # Update the Canvas container
    drawing_area.itemconfig(image_container, image=tkinter_image)


# User Interface Functions ----------------------------------------------------
def create_user_interface():
    global drawing_area, image_container, root

    root = tk.Tk()
    root.title("Demo: Scale Slider with Rotation")
    root.geometry("400x450")


    # Create Canvas Widget-----------------------------------------------------
    # Match the canvas background to constant for a seamless look
    hex_background = "#ecf0f1"

    drawing_area = tk.Canvas(
        root, 
        width=CANVAS_SIZE, 
        height=CANVAS_SIZE, 
        bg=hex_background, 
        highlightthickness=0
    )
    drawing_area.pack(pady=20)


    # Create Scale Slider Widget-----------------------------------------------------
    # The label for the directions
    directions = tk.Label(root, text="Rotate Shape 360 Degrees", font=("Helvetica", 11, "bold"))
    '''
    In Tkinter, the built-in label option for a horizontal Scale is hardcoded 
    to align to the top-left corner of the widget's area. So, there needs to be 
    a separate label or widget to center the directions.
    '''

    # Creates a object on the canvas to act as a placeholder for rendered frames
    image_container = drawing_area.create_image(150, 150, anchor="center")


    # Scale Widget Setup
    rotation_slider = tk.Scale(
        root, 
        from_=0,  # Starting value 
        to=360,  # Ending value 
        orient="horizontal",  # Either horizontal or vertical
        # label="Adjust Shape Size, # Un-center-able due to Tkinter's limitations        
        length=300,
        # fg=BORDER_COLOR, # Matches the slider text to the border color
        # highlightthickness=0,  # Removes the focus border gap
        command=handle_rotation  # Function to call on change
    )
    rotation_slider.pack(pady=10)
    rotation_slider.set(180)


# Main Application Window -----------------------------------------------------
if __name__ == "__main__":
    create_user_interface()  # Initialize UI
    root.mainloop()

