"""
Demo: Treeview Data Grid
Created: June 2, 2026

Description: Demonstrates multi-column tabular data management using the 
Treeview widget. Features programmatic row insertion, column weighting, 
auto-hiding scrollbars, and event-driven data extraction on row double-clicks.
"""

import tkinter as tk
from tkinter import ttk


# Widget Functions ------------------------------------------------------------
def auto_scroll(scrollbar: tk.Scrollbar, first: str | float, last: str | float) -> None:
    """
    Dynamically shows or hides a specific scrollbar depending on content size.
    """
    if float(first) <= 0.0 and float(last) >= 1.0:
        scrollbar.pack_forget()
    else:
        scrollbar.pack(side="right", fill="y")
        
    scrollbar.set(first, last)


def on_row_double_click(
    event: tk.Event, 
    treeview_widget: ttk.Treeview, 
    label_top: tk.Label, 
    label_bottom: tk.Label
) -> None:
    """
    Extracts structural record details from the clicked row to update status logs.
    """
    # Identify the specific row item ID that was double-clicked
    selected_item_id = treeview_widget.focus()
    
    if selected_item_id:
        # Retrieve the underlying database row dictionary values
        item_data = treeview_widget.item(selected_item_id)
        row_values = item_data["values"]  # Returns a list: [Asset ID, Name, Quantity, Status]

        asset_name = row_values[1]
        asset_status = row_values[3]

        # Route text feedback directly into the UI status loops
        label_top.config(text=f"Selected Record: {asset_name}")
        label_bottom.config(text=f"Current Operational Status: {asset_status}")


# Layout Component Builders ---------------------------------------------------
def build_treeview_grid(
    label_bottom: tk.Label, 
    label_top: tk.Label, 
    parent: tk.Misc
) -> ttk.Treeview:
    """
    Constructs a themed multi-column spreadsheet layout with scroll bindings.
    """

    # 1. Initialize a layout container and an independent scrollbar engine
    grid_container = tk.Frame(parent)
    grid_container.pack(fill="both", expand=True)
    
    scrollbar = tk.Scrollbar(grid_container, orient="vertical")

    # 2. Define our structural table columns
    # 'show="headings"' completely hides the native hierarchical folder tree column
    column_identifiers = ("id", "name", "quantity", "status")
    treeview_widget = ttk.Treeview(
        grid_container, 
        columns=column_identifiers, 
        show="headings",
        selectmode="browse"  # Limits selection to single rows
    )
    treeview_widget.pack(side="left", fill="both", expand=True)

    # 3. Hook the scrollbar directly to the Treeview's vertical movement axis
    treeview_widget.config(
        yscrollcommand=lambda first, last: auto_scroll(scrollbar, first, last)
    )
    scrollbar.config(command=treeview_widget.yview)

    # 4. Formatter Engine: Set Column Headers and Text Layout Alignment Rules
    # Column width rules
    treeview_widget.column("id", width=80, minwidth=60, stretch=False)
    treeview_widget.column("name", width=175, minwidth=125, stretch=True)
    treeview_widget.column("quantity", width=90, minwidth=70, stretch=False, anchor="center")
    treeview_widget.column("status", width=175, minwidth=125, stretch=False, anchor="center")

    # Visible Header labels
    treeview_widget.heading("id", text="Asset ID", anchor="w")
    treeview_widget.heading("name", text="Item Name", anchor="w")
    treeview_widget.heading("quantity", text="Stock Qty", anchor="center")
    treeview_widget.heading("status", text="Health Status", anchor="center")

    # 5. Event Binding Loop
    # Detects mouse button 1 double-clicks on table rows
    treeview_widget.bind(
        "<Double-1>", 
        lambda event: on_row_double_click(event, treeview_widget, label_top, label_bottom)
    )

    return treeview_widget


# User Interface Coordinator --------------------------------------------------
def create_user_interface() -> None:
    """
    Coordinates window initialization, UI theming configuration, and seed data insertion.
    """
    root = tk.Tk()
    root.title("Demo: Treeview Data Grid")
    root.geometry("650x380")
    root.resizable(True, True)  # Enabled resizing to show off stretching columns!

    # 1. Set Native OS Style Themes using ttk Styling Engines
    style_engine = ttk.Style()
    style_engine.theme_use("clam")  # Crisp, borderless engineering theme
    style_engine.configure("Treeview", rowheight=25)  # Set uniform row height for better readability

    # 2. Create structural frames
    main_frame = tk.Frame(root)
    main_frame.pack(fill="both", expand=True, padx=15, pady=15)

    # 3. Build status labels anchored underneath the data grid space
    status_display_top = tk.Label(root, text="Double-click any asset row to pull database logs", font=("Consolas", 11, "bold"), anchor="center")
    status_display_top.pack(side="top", fill="x", pady=(5, 0))

    status_display_bottom = tk.Label(root, text="", font=("Consolas", 11, "bold"), anchor="center")
    status_display_bottom.pack(side="top", fill="x", pady=(0, 25))

    # 4. Populate the horizontal data layout grid
    asset_grid = build_treeview_grid(status_display_bottom, status_display_top, main_frame)
 
    # 5. Database Seed Simulation
    # Array of tuple data structures representing backend database rows
    database_records = [
        ("AST-041", "Enterprise Database Server Blade", 4, "Optimal Operational Capacity"),
        ("AST-092", "Fiber Optic Routing Switch 24-Port", 12, "Maintenance Required (Port 4)"),
        ("AST-115", "Uninterruptible Power Supply (UPS)", 8, "Critical: Replace Battery Pack"),
        ("AST-204", "Biometric Network Security Scanner", 15, "Optimal Operational Capacity"),
        ("AST-318", "Network NAS Storage Array 64TB", 2, "Optimal Operational Capacity"),
        ("AST-440", "DevOps Local Staging Machine", 6, "Offline - Decommissioned"),
    ]

    for record in database_records:
        # Inserting items sequentially. tk.END appends them to the bottom of the ledger
        asset_grid.insert("", tk.END, values=record)

    root.mainloop()


# Main Application Entry ------------------------------------------------------
if __name__ == "__main__":
    create_user_interface()

