import tkinter as tk
from tkinter import ttk


# Widget Functions ------------------------------------------------------------
def auto_scroll(scrollbar: tk.Scrollbar, first: str | float, last: str | float) -> None:
    """
    Dynamically shows or hides a specific scrollbar depending on content size.
    """
    if float(first) <= 0.0 and float(last) >= 1.0:
        scrollbar.pack_forget()
    else:
        scrollbar.pack(side="right", fill="y")
        
    scrollbar.set(first, last)


def on_row_double_click(
    event: tk.Event, 
    treeview_widget: ttk.Treeview, 
    label_top: tk.Label, 
    label_bottom: tk.Label
) -> None:
    """
    Extracts hierarchical path and file details from the clicked node.
    """
    # Identify the specific row item ID that was double-clicked
    selected_item_id = treeview_widget.focus()
    
    if selected_item_id:
        # Retrieve the underlying database row dictionary values
        item_data = treeview_widget.item(selected_item_id)
        item_name = item_data["text"]  # This is the 'text' field of the item 
        row_values = item_data["values"]  # Returns a list: [Asset ID, Name, Quantity, Status]

        # Build a pseudo-directory file path by traversing upward to parent folder
        parent_id = treeview_widget.parent(selected_item_id)

        if parent_id:
            parent_name = treeview_widget.item(parent_id)["text"]
            full_path = f"root://{parent_name}/{item_name}"
            item_type = row_values[1]
            item_size = row_values[0]

            # Route text feedback directly into the UI status loops
            label_top.config(text=f"Opened File: {full_path}")
            label_bottom.config(text=f"Type: {item_type} | Allocate Size: {item_size}")
        else:
            # The item clicked is a root folder node
            label_top.config(text=f"Directory Expanded: root://{item_name}/")
            label_bottom.config(text="Scanning structural sub-directories...")


# Widget Creation -------------------------------------------------------------
def build_file_tree(
    label_bottom: tk.Label, 
    label_top: tk.Label, 
    parent: tk.Misc
) -> ttk.Treeview:
    """
    Constructs a themed multi-column spreadsheet layout with scroll bindings.
    """
    # 1. Initialize a layout container and an independent scrollbar engine
    grid_container = tk.Frame(parent)
    grid_container.pack(fill="both", expand=True)
    
    scrollbar = tk.Scrollbar(grid_container, orient="vertical")

    # 2. Define our structural table columns
    # 'show="headings"' completely hides the native hierarchical folder tree column
    column_identifiers = ("Size", "Type", "Modified")
    treeview_widget = ttk.Treeview(
        grid_container, 
        columns=column_identifiers, 
        show="tree headings",  # Activates both the hierarchical tree and the meta headers
        selectmode="browse"  # Limits selection to single rows
    )
    treeview_widget.pack(side="left", fill="both", expand=True)

    # 3. Hook the scrollbar directly to the Treeview's vertical movement axis
    treeview_widget.config(
        yscrollcommand=lambda first, last: auto_scroll(scrollbar, first, last)
    )
    scrollbar.config(command=treeview_widget.yview)

    # 4. Formatter Engine: Set Column Headers and Text Layout Alignment Rules
    # Column width rules
    treeview_widget.column("#0", width=250, minwidth=180, stretch=True)
    treeview_widget.column("Size", width=90, minwidth=70, stretch=False, anchor="w")
    treeview_widget.column("Type", width=120, minwidth=90, stretch=False, anchor="w")
    treeview_widget.column("Modified", width=130, minwidth=100, stretch=False, anchor="w")

    # Visible Header Labels
    treeview_widget.heading("#0", text="Project Directory Tree", anchor="w")
    treeview_widget.heading("Size", text="File Size", anchor="w")
    treeview_widget.heading("Type", text="Element Type", anchor="w")
    treeview_widget.heading("Modified", text="Date Modified", anchor="w")

    # 5. Event Binding Loop
    # Double-click binding on table rows
    treeview_widget.bind(
        "<Double-1>", 
        lambda event: on_row_double_click(event, treeview_widget, label_top, label_bottom)
    )

    return treeview_widget


# User Interface Coordinator --------------------------------------------------
def create_user_interface() -> None:
    """
    Coordinates window initialization, UI theming configuration, and seed data insertion.
    """
    root = tk.Tk()
    root.title("Demo: Treeview Data Grid")
    root.geometry("650x380")
    root.resizable(True, True)  # Enabled resizing to show off stretching columns!

    # 1. Set Native OS Style Themes using ttk Styling Engines
    style_engine = ttk.Style()
    style_engine.theme_use("clam")  # Crisp, borderless engineering theme
    style_engine.configure("Treeview", rowheight=25)  # Set uniform row height for better readability

    # 2. Create structural frames
    main_frame = tk.Frame(root)
    main_frame.pack(fill="both", expand=True, padx=15, pady=15)

    # 3. Build status labels anchored underneath the data grid space
    status_display_top = tk.Label(root, text="Double-click any file to read metadata paths", font=("Consolas", 11, "bold"), anchor="center")
    status_display_top.pack(side="top", fill="x", pady=(5, 0))  # pady=(10, 2))

    status_display_bottom = tk.Label(root, text="", font=("Consolas", 11, "bold"),anchor="center")
    status_display_bottom.pack(side="top", fill="x", pady=(0, 25))  # pady=(0, 25))

    file_tree = build_file_tree(status_display_bottom, status_display_top, main_frame)


    # Node Data for Debugging -----------------------------------------------

